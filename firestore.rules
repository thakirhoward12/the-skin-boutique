rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin check - looking up user privileges securely via the internal admins collection
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Owner check for users
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /products/{productId} {
      allow read: if true; // Public catalog
      allow write: if isAdmin(); // Admin only product management
    }
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow delete: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
    }

    match /favorites/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /orders/{orderId} {
      allow create: if true; // Allowing guest and authenticated checkouts
      allow read: if isAdmin(); // Only admins read order histories right now
      allow update, delete: if isAdmin();
    }
    
    match /walletTransactions/{transactionId} {
      allow create: if request.auth != null; // Created for referral rewards
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId; // Users can check their own admin status
      allow write: if false; // Admin docs are managed server-side only (grant_admin.mjs)
    }

    match /config/{document=**} {
      allow read, write: if isAdmin(); // Protects Shopify credentials in 'config/shopify'
    }
    
    match /{document=**} {
      allow read, write: if false; // Deny all explicitly unhandled collections to prevent data leaks
    }
  }
}
